# API Keys for LLM Providers
# Copy this file to .env and fill in your actual API keys
# Do NOT commit .env to git (it should be in .gitignore)

# OpenAI API Key (for GPT-4o)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Amazon Bedrock (for Claude 3.5 Sonnet)
# Option 1: Bedrock API Key (Preferred - simpler)
# Get from: https://console.aws.amazon.com/bedrock/
# Set this as AWS_BEARER_TOKEN_BEDROCK or BEDROCK_API_KEY
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here
AWS_REGION=us-east-1

# Option 2: AWS Credentials (Alternative - if you don't have a Bedrock API key)
# Get from: https://console.aws.amazon.com/iam/home#/security_credentials
# AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
# AWS_REGION=us-east-1

# Google API Key (for Gemini Pro 1.5)
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Together AI API Key (for LLaMA 3.1 70B and Qwen 2.5 72B)
# Get from: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=your_together_api_key_here

# OpenRouter API Key (for meta-llama/llama-4-scout, Claude via Anthropic, etc.)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic API Key (for Claude Haiku 4.5, Sonnet, etc. via native API)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here
